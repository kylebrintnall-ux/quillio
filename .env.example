# --- Required ---

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# The full JSON of a Google Cloud service account key, as a single-line string.
# Paste the entire downloaded key file here (escaped newlines in private_key are fine).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com"}

# Port the HTTP server listens on. Railway sets this automatically.
PORT=3000

# Slack incoming webhook the Block Kit result is posted to. It's a secret, so it
# is not baked into the code — set it here.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<TEAM_ID>/<BOT_ID>/<TOKEN>

# --- OAuth2 for Drive/Docs writes (optional; needed for personal Gmail) ---
# If GOOGLE_REFRESH_TOKEN is set, docs are created/written as this OAuth2 user
# instead of the service account (which has no personal storage quota). The
# Sheet is still read with the service account. See the README for how to mint
# the refresh token via the Google OAuth2 Playground. Leave unset to use the
# service account for everything (Google Workspace / Shared Drive path).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# --- Optional overrides (sensible defaults are baked in) ---

# Output destination adapter (src/destinations/). Only google-docs today.
# DESTINATION=google-docs

# Gemini model to use for parsing and drafting.
# GEMINI_MODEL=gemini-2.5-flash

# Google Sheet that holds the asset specs.
# SHEET_ID=1skbkkKlHMDUzeG8_bFpcSjrvweumivePuSOvr5qIfqk

# Google Drive folder the generated docs are created in.
# DRIVE_FOLDER_ID=1gdf5-R3J8IGY1I5pJJj2O-KFOju0UsqU

# Slack signing secret. If set, all incoming Slack requests are verified.
# SLACK_SIGNING_SECRET=
